project_name              = "agentic-commerce-assistant"
environment               = "dev"
aws_region                = "us-east-1"

lambda_function_name      = "agentic-commerce-backend-dev"
lambda_handler            = "app.backend.handler.handler"
lambda_runtime            = "python3.12"
lambda_timeout_seconds    = 30
lambda_memory_mb          = 512
lambda_artifact_path      = "../../artifacts/backend-lambda.zip"
lambda_log_retention_days = 14
enable_xray               = false

conversation_table_name   = "agentic-commerce-conversation-dev"
memory_ttl_days           = 7

api_name                  = "agentic-commerce-api-dev"
api_stage_name            = "$default"

create_docs_bucket        = false
docs_bucket_name          = "your-existing-docs-bucket"
docs_s3_prefix            = "phase1-kb/"

opensearch_collection_endpoint = "https://your-aoss-endpoint"
opensearch_index_name          = "policy-faq-chunks"

llm_provider              = "openai_compatible"
llm_api_key               = "set-via-secret-or-local-tfvars"
llm_base_url              = "https://r2lj67q.9router.com/v1"
llm_model                 = "cx/gpt-5.4"
llm_timeout_seconds       = 30
