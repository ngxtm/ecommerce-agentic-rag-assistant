project_name              = "agentic-commerce-assistant"
environment               = "dev"
aws_region                = "us-east-1"

lambda_function_name      = "agentic-commerce-backend-dev"
lambda_handler            = "run.sh"
lambda_runtime            = "python3.12"
lambda_timeout_seconds    = 60
lambda_memory_mb          = 1024
ingestion_lambda_timeout_seconds = 120
ingestion_lambda_memory_mb       = 1024
lambda_artifact_path      = "../../artifacts/backend-lambda.zip"
lambda_log_retention_days = 14
enable_xray               = true
lambda_architecture       = "x86_64"
lambda_web_adapter_layer_version = 25

conversation_table_name   = "agentic-commerce-conversation-dev"
memory_ttl_days           = 7

api_name                  = "agentic-commerce-api-dev"
api_stage_name            = "prod"

docs_s3_prefix            = "phase1-kb/"
enable_docs_ingestion_trigger = true
docs_ingestion_suffixes   = [".pdf", ".md", ".txt", ".docx"]
ingestion_state_ttl_days  = 30

opensearch_collection_name     = "agentic-commerce-knowledge-dev"
opensearch_collection_type     = "VECTORSEARCH"
opensearch_allow_public_access = true
opensearch_additional_principal_arns = [
  "arn:aws:iam::123456789012:user/your-local-user",
]
opensearch_local_iam_user_names = [
  "your-local-user",
]
opensearch_index_name          = "policy-faq-chunks"

llm_provider              = "openai_compatible"
llm_api_key               = "set-in-local-terraform.tfvars"
llm_base_url              = "https://r2lj67q.9router.com/v1"
llm_model                 = "cx/gpt-5.4"
llm_embedding_base_url    = "https://openrouter.ai/api/v1"
llm_embedding_model       = "qwen/qwen3-embedding-8b"
llm_embedding_dimensions  = 4096
llm_embedding_api_key     = "set-openrouter-key-in-local-terraform.tfvars"
llm_timeout_seconds       = 30
